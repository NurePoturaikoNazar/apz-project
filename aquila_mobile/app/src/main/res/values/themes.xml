<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Aquila_mobile" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/background_deep</item>
        <item name="android:statusBarColor">@color/background_deep</item>
        <item name="colorPrimary">@color/electric_blue</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSurface">@color/background_surface</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="Theme.Aquila_mobile" parent="Base.Theme.Aquila_mobile" />

    <!-- Glass Card Style -->
    <style name="GlassCard">
        <item name="cardBackgroundColor">@color/glass_overlay</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/glass_border</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>
