<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.aquila_mobile.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.aquila_mobile.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboardFragment_to_roomDetailsFragment"
            app:destination="@id/roomDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/alertsFragment"
        android:name="com.example.aquila_mobile.ui.alerts.AlertsFragment"
        android:label="Alerts"
        tools:layout="@layout/fragment_alerts">
        <action
            android:id="@+id/action_alertsFragment_to_alertDetailsFragment"
            app:destination="@id/alertDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/alertDetailsFragment"
        android:name="com.example.aquila_mobile.ui.alerts.AlertDetailsFragment"
        android:label="Alert Details"
        tools:layout="@layout/fragment_alert_details">
        <argument
            android:name="alertId"
            app:argType="string" />
        <argument
            android:name="deviceId"
            app:argType="string" />
        <argument
            android:name="alertType"
            app:argType="string" />
        <argument
            android:name="alertMessage"
            app:argType="string" />
        <argument
            android:name="timestamp"
            app:argType="string" />
        <action
            android:id="@+id/action_alertDetailsFragment_to_snapshotDetailsFragment"
            app:destination="@id/snapshotDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/snapshotDetailsFragment"
        android:name="com.example.aquila_mobile.ui.alerts.SnapshotDetailsFragment"
        android:label="Snapshot Details"
        tools:layout="@layout/fragment_snapshot_details">
        <argument
            android:name="imageUrl"
            app:argType="string" />
        <argument
            android:name="reason"
            app:argType="string" />
        <argument
            android:name="timestamp"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.aquila_mobile.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/adminProvisioningFragment"
        android:name="com.example.aquila_mobile.ui.admin.AdminProvisioningFragment"
        android:label="Provisioning"
        tools:layout="@layout/fragment_admin_provisioning" />

    <fragment
        android:id="@+id/roomDetailsFragment"
        android:name="com.example.aquila_mobile.ui.room.RoomDetailsFragment"
        android:label="Room Details"
        tools:layout="@layout/fragment_room_details">
        <argument
            android:name="roomId"
            app:argType="string" />
    </fragment>

    <!-- More fragments will be added here -->
</navigation>
